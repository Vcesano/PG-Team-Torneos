      "Bash(tasklist /FI \"PID eq 15340\")",
      "Bash(timeout 90 npm run build)",
      "Bash(timeout 8 npm run dev)",
      "Bash(timeout 30 npm test)",
      "Bash(npm run *)",
      "Bash(echo \"PID del proceso lanzado: $!\")",
      "Read(//tmp/**)",
